{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Hangfire": {
    "SchemaName": "Hangfire",
    "DashboardPath": "/hangfire"
  },
  "RefreshTokenCleanup": {
    "RetentionDays": 30,
    "Cron": "0 2 * * *"
  },
  "EmployeeReport": {
    "Cron": "0 6 * * *"
  },
  "FileUpload": {
    "Photo": {
      "MaxBytes": 10485760,
      "AllowedExtensions": [
        ".jpg",
        ".jpeg",
        ".png",
        ".webp"
      ]
    },
    "Document": {
      "MaxBytes": 10485760,
      "AllowedExtensions": [
        ".pdf",
        ".jpg",
        ".jpeg",
        ".png",
        ".docx",
        ".xlsx"
      ]
    }
  },
  "FileStorage": {
    "RootPath": "App_Data/uploads"
  },
  "AllowedHosts": "*"
}